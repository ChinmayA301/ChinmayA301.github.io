---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- assign visible_pages = site.pages | where_exp: "page", "page.url != nil" | where_exp: "page", "page.sitemap != false" -%}
{%- for page in visible_pages %}
  {%- unless page.url contains '/assets/' or page.url contains '/aegis-backend/' or page.url contains '/upload/' or page.url contains '/404.html' or page.url == '/sitemap.xml' %}
  <url>
    <loc>{{ page.url | absolute_url }}</loc>
    <lastmod>{{ page.last_modified_at | default: site.time | date_to_xmlschema }}</lastmod>
    <changefreq>{% if page.url == '/' %}weekly{% elsif page.url contains '/blog/' %}weekly{% else %}monthly{% endif %}</changefreq>
    <priority>{% if page.url == '/' %}1.0{% elsif page.url == '/blog/' or page.url == '/projects/' or page.url == '/ideas/' or page.url == '/experience/' %}0.9{% else %}0.7{% endif %}</priority>
  </url>
  {%- endunless %}
{%- endfor %}
{%- for post in site.posts %}
  <url>
    <loc>{{ post.url | absolute_url }}</loc>
    <lastmod>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>{% if post.visibility_priority %}{{ post.visibility_priority }}{% else %}0.8{% endif %}</priority>
  </url>
{%- endfor %}
</urlset>
